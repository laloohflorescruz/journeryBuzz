# Copia este archivo a .env y ajusta los valores para tu entorno local.
# Variables de Vite: deben llevar el prefijo VITE_ para exponerse al cliente.

# URL base de la API de backpacking-api. En producción apunta al dominio real.
VITE_API_BASE=http://localhost:8000/api

# Google Analytics 4 (measurement id, formato G-XXXXXXXXXX).
# Se obtiene en GA4 → Administrar → Flujos de datos → Web.
# Vacío = analytics desactivado.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google reCAPTCHA v3 — site key (pública, va en el navegador).
# Se obtiene en https://www.google.com/recaptcha/admin (tipo v3).
# Vacía = captcha desactivado. El backend valida con su RECAPTCHA_SECRET_KEY.
VITE_RECAPTCHA_SITE_KEY=tu-recaptcha-site-key
